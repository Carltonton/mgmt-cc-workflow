# API Keys Configuration
# Copy this file to .env and fill in your actual keys
# The .env file is gitignored and will NOT be committed

# Tavily API (required for /lit-search)
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# CrossRef Email (required for /lit-search)
# Use your institutional email for better rate limits
CROSSREF_EMAIL=your-email@example.com

# Semantic Scholar API (optional, increases rate limits)
# Get your key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Anthropic API Key (if using API key auth instead of browser sign-in)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
